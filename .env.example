# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://renewpilot:renewpilot@localhost:5432/renewpilot_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — use long random secrets in production (min 32 chars)
JWT_ACCESS_SECRET=change-me-to-a-random-32-char-secret-access
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change-me-to-a-random-32-char-secret-refresh
JWT_REFRESH_EXPIRES=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Stripe
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Email (Resend)
RESEND_API_KEY=re_placeholder
EMAIL_FROM=noreply@renewpilot.io

# Frontend
FRONTEND_URL=http://localhost:5173
