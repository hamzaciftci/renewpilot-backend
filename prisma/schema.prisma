generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum AssetType {
  DOMAIN
  SERVER
  SSL_CERTIFICATE
  LICENSE
  HOSTING_SERVICE
  CDN_SERVICE
  CREDIT_CARD
  CUSTOM
}

enum AssetStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  CANCELLED
  ARCHIVED
}

enum RenewalEventType {
  CREATED
  RENEWED
  EXPIRY_UPDATED
  CANCELLED
  REMINDER_SENT
}

enum NotificationChannel {
  EMAIL
  PUSH
  SMS
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  INCOMPLETE
}

enum PlanCode {
  FREE
  PRO
  AGENCY
  ENTERPRISE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

// ─── Core Identity Tables ─────────────────────────────────────────────────────

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String     @map("password_hash")
  fullName        String     @map("full_name")
  avatarUrl       String?    @map("avatar_url")
  defaultTimezone String     @default("UTC") @map("default_timezone")
  locale          String     @default("en")
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  phoneNumber     String?    @map("phone_number")
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  ownedOrganizations    Organization[]       @relation("OrgOwner")
  memberships           OrganizationMember[]
  assignedAssets        Asset[]              @relation("AssetAssignedUser")
  refreshTokens         RefreshToken[]
  notifications         Notification[]
  pushSubscriptions     WebPushSubscription[]
  createdAuditLogs      AuditLog[]
  createdShareLinks     AssetShareLink[]     @relation("ShareLinkCreator")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Organization (Tenant) Tables ─────────────────────────────────────────────

model Organization {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  ownerUserId String    @map("owner_user_id")
  planId      String?   @map("plan_id")
  timezone    String    @default("UTC")
  currency    String    @default("USD")
  status      OrgStatus @default(ACTIVE)
  trialEndsAt DateTime? @map("trial_ends_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  owner            User                 @relation("OrgOwner", fields: [ownerUserId], references: [id])
  plan             Plan?                @relation(fields: [planId], references: [id])
  members          OrganizationMember[]
  invitations      Invitation[]
  projects         Project[]
  assets           Asset[]
  reminderPolicies ReminderPolicy[]
  notifications    Notification[]
  subscription     Subscription?
  auditLogs        AuditLog[]

  @@map("organizations")
}

model OrganizationMember {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  userId         String     @map("user_id")
  role           MemberRole @default(MEMBER)
  invitedByUserId String?   @map("invited_by_user_id")
  invitedAt      DateTime?  @map("invited_at")
  joinedAt       DateTime   @default(now()) @map("joined_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

// ─── Project Tables ───────────────────────────────────────────────────────────

model Project {
  id              String        @id @default(uuid())
  organizationId  String        @map("organization_id")
  name            String
  description     String?
  clientName      String?       @map("client_name")
  colorTag        String?       @map("color_tag")
  status          ProjectStatus @default(ACTIVE)
  createdByUserId String?       @map("created_by_user_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assets       Asset[]

  @@index([organizationId])
  @@map("projects")
}

// ─── Asset Tables ─────────────────────────────────────────────────────────────

model Asset {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  projectId      String?     @map("project_id")
  assetType      AssetType   @map("asset_type")
  name           String
  vendorName     String?     @map("vendor_name")
  status         AssetStatus @default(ACTIVE)
  renewalDate    DateTime    @map("renewal_date")
  renewalIntervalUnit  String? @default("year") @map("renewal_interval_unit")
  renewalIntervalValue Int?   @default(1) @map("renewal_interval_value")
  autoRenewEnabled     Boolean @default(false) @map("auto_renew_enabled")
  priceAmount    Decimal?    @db.Decimal(12, 2) @map("price_amount")
  priceCurrency  String      @default("USD") @map("price_currency")
  assignedUserId String?     @map("assigned_user_id")
  notes          String?
  metadata       Json?
  lastRenewedAt  DateTime?   @map("last_renewed_at")
  createdByUserId String?    @map("created_by_user_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?      @relation(fields: [projectId], references: [id])
  assignedUser   User?         @relation("AssetAssignedUser", fields: [assignedUserId], references: [id])
  renewalEvents  RenewalEvent[]
  notifications  Notification[]

  domain         Domain?
  server         Server?
  sslCertificate SslCertificate?
  license        License?
  hostingService HostingService?
  cdnService     CdnService?
  shareLinks     AssetShareLink[]

  @@index([organizationId])
  @@index([organizationId, renewalDate])
  @@index([organizationId, assetType])
  @@index([organizationId, status])
  @@index([organizationId, projectId])
  @@map("assets")
}

// ─── Asset Subtype Tables ─────────────────────────────────────────────────────

model Domain {
  id               String    @id @default(uuid())
  assetId          String    @unique @map("asset_id")
  domainName       String?   @map("domain_name")
  registrar        String?
  tld              String?
  nameserverProvider String? @map("nameserver_provider")
  autoRenew        Boolean   @default(false) @map("auto_renew")
  transferLock     Boolean   @default(false) @map("transfer_lock")
  privacyProtection Boolean  @default(false) @map("privacy_protection")
  whoisExpiryDate  DateTime? @map("whois_expiry_date")
  registrationDate DateTime? @map("registration_date")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("domains")
}

model Server {
  id            String   @id @default(uuid())
  assetId       String   @unique @map("asset_id")
  serverType    String?  @map("server_type")
  provider      String?
  hostname      String?
  ipAddress     String?  @map("ip_address")
  operatingSystem String? @map("operating_system")
  region        String?
  controlPanel  String?  @map("control_panel")
  billingCycle  String?  @map("billing_cycle")
  specs         Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("servers")
}

model SslCertificate {
  id              String    @id @default(uuid())
  assetId         String    @unique @map("asset_id")
  commonName      String?   @map("common_name")
  issuer          String?
  certificateType String?   @map("certificate_type")
  validFrom       DateTime? @map("valid_from")
  validTo         DateTime? @map("valid_to")
  isWildcard      Boolean   @default(false) @map("is_wildcard")
  autoRenew       Boolean   @default(false) @map("auto_renew")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("ssl_certificates")
}

model License {
  id              String   @id @default(uuid())
  assetId         String   @unique @map("asset_id")
  softwareName    String?  @map("software_name")
  licenseKey      String?  @map("license_key")
  licenseType     String?  @map("license_type")
  seatCount       Int?     @map("seat_count")
  vendorPortalUrl String?  @map("vendor_portal_url")
  assignedTo      String?  @map("assigned_to")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("licenses")
}

model HostingService {
  id               String   @id @default(uuid())
  assetId          String   @unique @map("asset_id")
  provider         String?
  hostingType      String?  @map("hosting_type")
  planName         String?  @map("plan_name")
  controlPanel     String?  @map("control_panel")
  datacenterRegion String?  @map("datacenter_region")
  billingCycle     String?  @map("billing_cycle")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("hosting_services")
}

model CdnService {
  id           String   @id @default(uuid())
  assetId      String   @unique @map("asset_id")
  provider     String?
  planName     String?  @map("plan_name")
  zoneCount    Int?     @map("zone_count")
  billingCycle String?  @map("billing_cycle")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("cdn_services")
}

model CustomAsset {
  id           String   @id @default(uuid())
  assetId      String   @unique @map("asset_id")
  categoryName String?  @map("category_name")
  customFields Json?    @map("custom_fields")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("custom_assets")
}

// ─── Renewal & Reminder Tables ────────────────────────────────────────────────

model RenewalEvent {
  id                String           @id @default(uuid())
  assetId           String           @map("asset_id")
  eventType         RenewalEventType @map("event_type")
  eventDate         DateTime         @default(now()) @map("event_date")
  oldRenewalDate    DateTime?        @map("old_renewal_date")
  newRenewalDate    DateTime?        @map("new_renewal_date")
  performedByUserId String?          @map("performed_by_user_id")
  notes             String?
  createdAt         DateTime         @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("renewal_events")
}

model ReminderPolicy {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  offsetDays     Json     @map("offset_days")
  channelConfig  Json     @map("channel_config")
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("reminder_policies")
}

// ─── Notification Tables ──────────────────────────────────────────────────────

model Notification {
  id               String              @id @default(uuid())
  organizationId   String              @map("organization_id")
  userId           String              @map("user_id")
  assetId          String?             @map("asset_id")
  channel          NotificationChannel
  notificationType String              @map("notification_type")
  subject          String?
  body             String?
  status           NotificationStatus  @default(PENDING)
  providerName     String?             @map("provider_name")
  providerMessageId String?            @map("provider_message_id")
  scheduledFor     DateTime            @map("scheduled_for")
  sentAt           DateTime?           @map("sent_at")
  deliveredAt      DateTime?           @map("delivered_at")
  readAt           DateTime?           @map("read_at")
  failedAt         DateTime?           @map("failed_at")
  failureReason    String?             @map("failure_reason")
  retryCount       Int                 @default(0) @map("retry_count")
  payload          Json?
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  asset        Asset?       @relation(fields: [assetId], references: [id])

  @@index([organizationId, status, scheduledFor])
  @@index([userId, status])
  @@map("notifications")
}

model WebPushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("web_push_subscriptions")
}

model NotificationPreference {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  organizationId   String   @map("organization_id")
  pushEnabled      Boolean  @default(true) @map("push_enabled")
  emailEnabled     Boolean  @default(true) @map("email_enabled")
  smsEnabled       Boolean  @default(false) @map("sms_enabled")
  whatsappEnabled  Boolean  @default(false) @map("whatsapp_enabled")
  quietHoursStart  String?  @map("quiet_hours_start")
  quietHoursEnd    String?  @map("quiet_hours_end")
  digestFrequency  String   @default("none") @map("digest_frequency")
  timezone         String   @default("UTC")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([userId, organizationId])
  @@map("notification_preferences")
}

// ─── Billing Tables ───────────────────────────────────────────────────────────

model Plan {
  id                   String   @id @default(uuid())
  code                 PlanCode @unique
  name                 String
  monthlyPrice         Decimal  @db.Decimal(10, 2) @map("monthly_price")
  yearlyPrice          Decimal  @db.Decimal(10, 2) @map("yearly_price")
  currency             String   @default("USD")
  maxAssets            Int      @map("max_assets")
  maxTeamMembers       Int      @map("max_team_members")
  channels             Json
  features             Json
  stripePriceIdMonthly String?  @map("stripe_price_id_monthly")
  stripePriceIdYearly  String?  @map("stripe_price_id_yearly")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  organizations Organization[]
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  organizationId       String             @unique @map("organization_id")
  planId               String             @map("plan_id")
  billingProvider      String             @default("stripe") @map("billing_provider")
  providerCustomerId   String?            @map("provider_customer_id")
  providerSubscriptionId String?          @unique @map("provider_subscription_id")
  status               SubscriptionStatus @default(TRIALING)
  billingInterval      BillingInterval    @map("billing_interval")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  trialEndsAt          DateTime?          @map("trial_ends_at")
  cancelledAt          DateTime?          @map("cancelled_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  plan         Plan         @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model Payment {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  subscriptionId  String?  @map("subscription_id")
  providerPaymentId String? @map("provider_payment_id")
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("USD")
  status          String
  paidAt          DateTime? @map("paid_at")
  invoiceUrl      String?   @map("invoice_url")
  receiptUrl      String?   @map("receipt_url")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("payments")
}

// ─── Invitation Table ─────────────────────────────────────────────────────────

model Invitation {
  id               String           @id @default(uuid())
  organizationId   String           @map("organization_id")
  email            String
  role             MemberRole       @default(MEMBER)
  tokenHash        String           @unique @map("token_hash")
  invitedByUserId  String           @map("invited_by_user_id")
  status           InvitationStatus @default(PENDING)
  expiresAt        DateTime         @map("expires_at")
  acceptedAt       DateTime?        @map("accepted_at")
  acceptedByUserId String?          @map("accepted_by_user_id")
  revokedAt        DateTime?        @map("revoked_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([email, status])
  @@map("invitations")
}

// ─── Asset Share Link Table ───────────────────────────────────────────────────

/// Read-only public links to an asset. The plaintext token is shown to the
/// creator once on creation; only the SHA-256 hash is stored. Looking up a
/// link from a public URL hashes the URL token and matches against tokenHash.
model AssetShareLink {
  id              String    @id @default(uuid())
  assetId         String    @map("asset_id")
  tokenHash       String    @unique @map("token_hash")
  label           String?
  createdByUserId String    @map("created_by_user_id")
  expiresAt       DateTime? @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")
  viewCount       Int       @default(0) @map("view_count")
  lastViewedAt    DateTime? @map("last_viewed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  asset     Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy User  @relation("ShareLinkCreator", fields: [createdByUserId], references: [id])

  @@index([assetId])
  @@map("asset_share_links")
}

// ─── Audit Table ──────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  actorUserId    String?  @map("actor_user_id")
  action         String
  resourceType   String   @map("resource_type")
  resourceId     String?  @map("resource_id")
  diff           Json?
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  actor        User?        @relation(fields: [actorUserId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, resourceType, resourceId])
  @@map("audit_logs")
}
